<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order Confirmed - ShopHub</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <%- include('partials/header') %>

  <main>
    <div class="container" style="padding: 4rem 20px;">
      <div class="confirmation-card">
        <div class="confirmation-icon">
          <i class="fas fa-check-circle"></i>
        </div>
        <h1>Order Placed Successfully!</h1>
        <p class="confirmation-subtitle">Thank you, <strong><%= user.name %></strong>! Your order has been received.</p>
        <div class="order-id-badge">Order #<%= order.id %></div>

        <div class="confirmation-details">
          <div class="conf-section">
            <h3><i class="fas fa-box"></i> Order Items</h3>
            <% order.orderItems.forEach(item => { %>
              <div class="conf-item">
                <img src="<%= item.image %>" alt="<%= item.name %>">
                <div>
                  <div class="conf-item-name"><%= item.name %></div>
                  <div class="conf-item-meta">Qty: <%= item.quantity %> &times; ₹<%= item.price.toLocaleString('en-IN') %></div>
                </div>
                <div class="conf-item-total">₹<%= (item.price * item.quantity).toLocaleString('en-IN') %></div>
              </div>
            <% }); %>
          </div>

          <div class="conf-section">
            <h3><i class="fas fa-map-marker-alt"></i> Shipping To</h3>
            <p><strong><%= order.customerName %></strong></p>
            <p><%= order.shippingAddress.address %></p>
            <p><%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> - <%= order.shippingAddress.pincode %></p>
            <p><i class="fas fa-phone"></i> <%= order.phone %></p>
          </div>

          <div class="conf-section">
            <h3><i class="fas fa-receipt"></i> Payment Summary</h3>
            <div class="conf-totals">
              <div class="conf-total-row"><span>Subtotal:</span><span>₹<%= order.subtotal.toLocaleString('en-IN') %></span></div>
              <div class="conf-total-row"><span>Shipping:</span><span><%= order.shipping === 0 ? 'Free' : '₹' + order.shipping %></span></div>
              <div class="conf-total-row"><span>GST (18%):</span><span>₹<%= order.tax.toLocaleString('en-IN') %></span></div>
              <div class="conf-total-row final"><span>Total Paid:</span><span>₹<%= order.total.toLocaleString('en-IN') %></span></div>
            </div>
            <p class="payment-method-info">
              <i class="fas fa-credit-card"></i>
              Payment via <strong><%= order.paymentMethod.toUpperCase() %></strong>
            </p>
          </div>
        </div>

        <div class="confirmation-actions">
          <a href="/my-orders" class="btn btn-primary">
            <i class="fas fa-box"></i> View My Orders
          </a>
          <a href="/" class="btn btn-secondary">
            <i class="fas fa-shopping-bag"></i> Continue Shopping
          </a>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
