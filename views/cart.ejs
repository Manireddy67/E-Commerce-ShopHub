<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shopping Cart - ShopHub</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <%- include('partials/header') %>

  <main>
    <div class="container cart-page">
      <div class="page-title-bar">
        <h1><i class="fas fa-shopping-cart"></i> Shopping Cart</h1>
        <a href="/" class="btn-back"><i class="fas fa-arrow-left"></i> Continue Shopping</a>
      </div>

      <% if (cartItems.length === 0) { %>
        <div class="empty-cart">
          <i class="fas fa-shopping-cart" style="font-size:5rem; color:#ddd; display:block; margin-bottom:1.5rem;"></i>
          <h2>Your cart is empty</h2>
          <p>Looks like you haven't added anything yet.</p>
          <a href="/" class="btn btn-primary" style="margin-top:1.5rem;">Start Shopping</a>
        </div>
      <% } else { %>
        <div class="cart-grid">
          <div class="cart-items">
            <% cartItems.forEach(item => { %>
              <div class="cart-item" id="cart-item-<%= item.id %>">
                <a href="/product/<%= item.id %>">
                  <img src="<%= item.image %>" alt="<%= item.name %>">
                </a>
                <div class="cart-item-info">
                  <a href="/product/<%= item.id %>"><h3><%= item.name %></h3></a>
                  <p class="cart-item-category"><i class="fas fa-tag"></i> <%= item.category %></p>
                  <p class="cart-unit-price">₹<%= item.price.toLocaleString('en-IN') %> each</p>
                </div>
                <div class="cart-qty-control">
                  <button class="qty-btn" onclick="updateQty(<%= item.id %>, <%= item.quantity - 1 %>)">
                    <i class="fas fa-minus"></i>
                  </button>
                  <span class="qty-display" id="qty-<%= item.id %>"><%= item.quantity %></span>
                  <button class="qty-btn" onclick="updateQty(<%= item.id %>, <%= item.quantity + 1 %>)">
                    <i class="fas fa-plus"></i>
                  </button>
                </div>
                <div class="cart-item-price" id="price-<%= item.id %>">
                  ₹<%= (item.price * item.quantity).toLocaleString('en-IN') %>
                </div>
                <button class="btn-remove" onclick="removeFromCart(<%= item.id %>)" title="Remove">
                  <i class="fas fa-trash"></i>
                </button>
              </div>
            <% }); %>
          </div>

          <div class="cart-summary">
            <h2>Order Summary</h2>
            <div class="summary-row">
              <span>Subtotal:</span>
              <span id="summarySubtotal">₹<%= subtotal.toLocaleString('en-IN') %></span>
            </div>
            <div class="summary-row">
              <span>Shipping:</span>
              <span id="summaryShipping"><%= shipping === 0 ? 'Free' : '₹' + shipping %></span>
            </div>
            <% if (shipping > 0) { %>
              <p class="free-shipping-note">
                <i class="fas fa-info-circle"></i>
                Add ₹<%= (999 - subtotal + shipping).toLocaleString('en-IN') %> more for free shipping
              </p>
            <% } %>
            <div class="summary-row total">
              <span>Total:</span>
              <span id="summaryTotal">₹<%= total.toLocaleString('en-IN') %></span>
            </div>
            <a href="/checkout" class="btn btn-primary btn-large checkout-btn">
              <i class="fas fa-lock"></i> Proceed to Checkout
            </a>
            <div class="cart-trust">
              <span><i class="fas fa-shield-alt"></i> Secure Checkout</span>
              <span><i class="fas fa-undo"></i> Easy Returns</span>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="/js/main.js"></script>
  <script>
    function updateQty(productId, newQty) {
      fetch('/cart/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId, quantity: newQty })
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          if (newQty <= 0) {
            document.getElementById('cart-item-' + productId).remove();
          } else {
            document.getElementById('qty-' + productId).textContent = newQty;
          }
          // Update totals
          document.getElementById('summarySubtotal').textContent = '₹' + data.subtotal.toLocaleString('en-IN');
          document.getElementById('summaryShipping').textContent = data.shipping === 0 ? 'Free' : '₹' + data.shipping;
          document.getElementById('summaryTotal').textContent = '₹' + data.total.toLocaleString('en-IN');
          document.getElementById('cartCount').textContent = data.cartCount;
          // Reload if cart empty
          if (data.cartCount === 0) location.reload();
        }
      });
    }
  </script>
</body>
</html>
