<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.name %> - ShopHub</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <%- include('partials/header') %>

  <main>
    <div class="container product-detail">
      <!-- Breadcrumb -->
      <nav class="breadcrumb">
        <a href="/"><i class="fas fa-home"></i> Home</a>
        <span>/</span>
        <a href="/?category=<%= product.category %>"><%= product.category %></a>
        <span>/</span>
        <span><%= product.name %></span>
      </nav>

      <div class="product-detail-grid">
        <div class="product-detail-image">
          <img src="<%= product.image %>" alt="<%= product.name %>">
          <div class="product-detail-badge">
            <% if (product.price < 5000) { %>
              <span class="badge badge-hot">Best Deal</span>
            <% } else if (product.price > 50000) { %>
              <span class="badge badge-premium">Premium</span>
            <% } else { %>
              <span class="badge badge-popular">Popular</span>
            <% } %>
          </div>
        </div>

        <div class="product-detail-info">
          <div class="product-category">
            <% if (product.category === 'Electronics') { %>
              <i class="fas fa-microchip"></i>
            <% } else { %>
              <i class="fas fa-dumbbell"></i>
            <% } %>
            <%= product.category %>
          </div>

          <h1><%= product.name %></h1>

          <div class="product-rating" style="margin-bottom:1rem;">
            <div class="stars">
              <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
              <i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i>
            </div>
            <span class="rating-text">4.5 (128 reviews)</span>
          </div>

          <div class="price-container" style="margin-bottom:1.5rem;">
            <span class="price-large">₹<%= product.price.toLocaleString('en-IN') %></span>
            <% if (product.price > 10000) { %>
              <span class="original-price" style="font-size:1.2rem;">₹<%= Math.round(product.price * 1.2).toLocaleString('en-IN') %></span>
              <span class="discount">17% OFF</span>
            <% } %>
          </div>

          <p class="description-full"><%= product.description %></p>

          <div class="product-detail-features">
            <div class="detail-feature">
              <i class="fas fa-truck"></i>
              <span>Free delivery on orders above ₹999</span>
            </div>
            <% if (product.category === 'Electronics') { %>
              <div class="detail-feature">
                <i class="fas fa-certificate"></i>
                <span>1 Year Manufacturer Warranty</span>
              </div>
            <% } %>
            <div class="detail-feature">
              <i class="fas fa-undo"></i>
              <span>7-day easy return policy</span>
            </div>
            <div class="detail-feature">
              <i class="fas fa-shield-alt"></i>
              <span>100% Authentic Product</span>
            </div>
          </div>

          <div class="quantity-selector">
            <label for="quantity">Quantity:</label>
            <div class="qty-input-group">
              <button type="button" onclick="changeQty(-1)" class="qty-btn">
                <i class="fas fa-minus"></i>
              </button>
              <input type="number" id="quantity" value="1" min="1" max="10" readonly>
              <button type="button" onclick="changeQty(1)" class="qty-btn">
                <i class="fas fa-plus"></i>
              </button>
            </div>
          </div>

          <div class="product-detail-actions">
            <button class="btn btn-primary btn-large" onclick="addToCartWithQuantity(<%= product.id %>)">
              <i class="fas fa-shopping-cart"></i> Add to Cart
            </button>
            <button class="btn-wishlist-lg" onclick="toggleWishlistDetail(<%= product.id %>, this)">
              <i class="far fa-heart"></i>
            </button>
          </div>

          <a href="/" class="btn-back-link"><i class="fas fa-arrow-left"></i> Continue Shopping</a>
        </div>
      </div>

      <!-- Related Products -->
      <% if (related && related.length > 0) { %>
        <div class="related-products">
          <div class="section-header" style="margin-bottom:2rem;">
            <h2>Related Products</h2>
            <p>You might also like these</p>
          </div>
          <div class="products-grid">
            <% related.forEach(rp => { %>
              <div class="product-card" data-category="<%= rp.category %>">
                <div class="product-badge">
                  <% if (rp.price < 5000) { %>
                    <span class="badge badge-hot">Best Deal</span>
                  <% } else if (rp.price > 50000) { %>
                    <span class="badge badge-premium">Premium</span>
                  <% } else { %>
                    <span class="badge badge-popular">Popular</span>
                  <% } %>
                </div>
                <a href="/product/<%= rp.id %>" class="product-link">
                  <div class="product-image">
                    <img src="<%= rp.image %>" alt="<%= rp.name %>" loading="lazy">
                    <div class="product-overlay">
                      <div class="overlay-content"><i class="fas fa-eye"></i><span>Quick View</span></div>
                    </div>
                  </div>
                  <div class="product-info">
                    <div class="product-category"><i class="fas fa-tag"></i> <%= rp.category %></div>
                    <h3><%= rp.name %></h3>
                    <div class="price-container">
                      <span class="price">₹<%= rp.price.toLocaleString('en-IN') %></span>
                    </div>
                  </div>
                </a>
                <div class="product-actions">
                  <button class="btn-add-cart" data-product-id="<%= rp.id %>">
                    <i class="fas fa-shopping-cart"></i> Add to Cart
                  </button>
                  <button class="btn-wishlist" data-product-id="<%= rp.id %>">
                    <i class="far fa-heart"></i>
                  </button>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      <% } %>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="/js/main.js"></script>
  <script>
    function changeQty(delta) {
      const input = document.getElementById('quantity');
      const newVal = Math.max(1, Math.min(10, parseInt(input.value) + delta));
      input.value = newVal;
    }

    function toggleWishlistDetail(productId, btn) {
      toggleWishlist(productId, btn);
    }

    // Init wishlist state
    document.addEventListener('DOMContentLoaded', function() {
      const wishlist = JSON.parse(localStorage.getItem('wishlist')) || [];
      const btn = document.querySelector('.btn-wishlist-lg');
      if (btn && wishlist.includes(<%= product.id %>)) {
        btn.innerHTML = '<i class="fas fa-heart"></i>';
        btn.style.color = '#ff6b35';
      }
    });
  </script>
</body>
</html>
