<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Customers Management - ShopHub Admin</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
  <div class="admin-layout">
    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="admin-logo">
        <i class="fas fa-store"></i>
        <h2>ShopHub Admin</h2>
      </div>
      
      <nav class="admin-nav">
        <a href="/admin/dashboard" class="admin-nav-item">
          <i class="fas fa-chart-line"></i>
          <span>Dashboard</span>
        </a>
        <a href="/admin/orders" class="admin-nav-item">
          <i class="fas fa-shopping-bag"></i>
          <span>Orders</span>
        </a>
        <a href="/admin/products" class="admin-nav-item">
          <i class="fas fa-box"></i>
          <span>Products</span>
        </a>
        <a href="/admin/customers" class="admin-nav-item active">
          <i class="fas fa-users"></i>
          <span>Customers</span>
        </a>
        <a href="/" class="admin-nav-item" target="_blank">
          <i class="fas fa-external-link-alt"></i>
          <span>View Store</span>
        </a>
        <a href="/admin/logout" class="admin-nav-item logout">
          <i class="fas fa-sign-out-alt"></i>
          <span>Logout</span>
        </a>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="admin-main">
      <header class="admin-header">
        <h1>Customers Management</h1>
        <div class="admin-user">
          <i class="fas fa-user-shield"></i>
          <span>Admin</span>
        </div>
      </header>

      <!-- Search -->
      <div class="admin-filters">
        <div class="filter-group">
          <label>Search:</label>
          <input type="text" id="searchCustomer" placeholder="Customer name or email">
        </div>
      </div>

      <!-- Customers Table -->
      <div class="admin-section">
        <div class="admin-table-container">
          <table class="admin-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Registered Date</th>
                <th>Total Orders</th>
                <th>Total Spent</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="customersTableBody">
              <% if (customers.length === 0) { %>
                <tr>
                  <td colspan="7" style="text-align: center; padding: 3rem;">
                    <i class="fas fa-users" style="font-size: 4rem; color: #ccc; display: block; margin-bottom: 1rem;"></i>
                    <h3>No customers yet</h3>
                    <p>Customers will appear here once they register</p>
                  </td>
                </tr>
              <% } else { %>
                <% customers.forEach(function(customer, index) { %>
                  <tr>
                    <td><strong>#<%= index + 1 %></strong></td>
                    <td><%= customer.name %></td>
                    <td><%= customer.email %></td>
                    <td><%= customer.registeredDate ? new Date(customer.registeredDate).toLocaleDateString('en-IN') : 'N/A' %></td>
                    <td><%= customer.totalOrders || 0 %></td>
                    <td><strong>₹<%= (customer.totalSpent || 0).toLocaleString('en-IN') %></strong></td>
                    <td>
                      <button class="btn-icon" title="View Details">
                        <i class="fas fa-eye"></i>
                      </button>
                    </td>
                  </tr>
                <% }); %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

  <script src="/js/main.js"></script>
  <script>
    // Simple search functionality
    document.getElementById('searchCustomer').addEventListener('keyup', function() {
      const searchTerm = this.value.toLowerCase();
      const rows = document.querySelectorAll('#customersTableBody tr');
      
      rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(searchTerm) ? '' : 'none';
      });
    });
  </script>
</body>
</html>
